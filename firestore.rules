rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isSurveyOwner(surveyId) {
      return isSignedIn()
             && get(/databases/$(database)/documents/surveys/$(surveyId)).data.createdBy == request.auth.uid;
    }

    // ─── Users collection ──────────────────────
    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ─── Surveys collection ────────────────────
    match /surveys/{surveyId} {
      // Owner can always read their own surveys; public can only read active (published) surveys
      allow read: if (isSignedIn() && resource.data.createdBy == request.auth.uid)
                  || resource.data.status == 'active';

      // Only authenticated users can create surveys
      allow create: if isSignedIn()
                    && request.resource.data.createdBy == request.auth.uid;

      // Only the survey owner can update or delete
      allow update, delete: if isSignedIn()
                            && resource.data.createdBy == request.auth.uid;
    }

    // ─── Responses collection ──────────────────
    match /responses/{responseId} {
      // Anyone can submit a response (public, no auth)
      allow create: if true;

      // Only the survey owner can read responses
      allow read: if isSurveyOwner(resource.data.surveyId);

      // Responses cannot be updated or deleted
      allow update, delete: if false;
    }
  }
}
